<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
/* ======= NAV SCROLL ======= */
const navbar = document.getElementById("navbar");
window.addEventListener("scroll", () => { navbar.classList.toggle("scrolled", window.scrollY > 40); }, {passive:true});

/* ======= SMOOTH SCROLL — intercept ALL internal anchor clicks =======
   Adaptive: re-scrolls if the target's position shifts within ~2s of the
   click, so late-loading content (Future Ticketing widget, lazy images,
   embeds) doesn't strand the user mid-page. Bails on any user input. */
function smoothScrollTo(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const offset = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-h")) || 72;
  const targetTop = () => el.getBoundingClientRect().top + window.scrollY - offset;

  window.scrollTo({ top: targetTop(), behavior: "smooth" });

  let lastTarget = targetTop();
  let interrupted = false;
  const stopWatching = () => { interrupted = true; };
  // Treat any explicit user input as a signal to stop chasing the target
  window.addEventListener("wheel",      stopWatching, { passive: true, once: true });
  window.addEventListener("touchstart", stopWatching, { passive: true, once: true });
  window.addEventListener("keydown",    stopWatching, { once: true });

  // Poll the target every 100ms for 2s; re-scroll if content above the target
  // has shifted it by more than 4px (filters rounding noise from layout calcs)
  const intervalId = setInterval(() => {
    if (interrupted) { clearInterval(intervalId); return; }
    const newTarget = targetTop();
    if (Math.abs(newTarget - lastTarget) > 4) {
      window.scrollTo({ top: newTarget, behavior: "smooth" });
      lastTarget = newTarget;
    }
  }, 100);

  setTimeout(() => {
    clearInterval(intervalId);
    window.removeEventListener("wheel",      stopWatching);
    window.removeEventListener("touchstart", stopWatching);
    window.removeEventListener("keydown",    stopWatching);
  }, 2000);
}

document.addEventListener("click", function(e) {
  const a = e.target.closest("a[href^='#']");
  if (!a) return;
  const id = a.getAttribute("href").slice(1);
  if (!id) return;
  e.preventDefault();
  smoothScrollTo(id);
});

/* ======= MOBILE NAV ======= */
function closeMobile() { document.getElementById("mobile-nav").classList.remove("open"); }

/* ======= COUNTDOWN ======= */
const EVENT_DATE = new Date("2026-06-23T12:00:00");
function pad(n) { return String(n).padStart(2,"0"); }
function updateCd() {
  const d = EVENT_DATE - new Date();
  if (d <= 0) { document.getElementById("countdown").style.display = "none"; return; }
  document.getElementById("cd-days").textContent  = pad(Math.floor(d/86400000));
  document.getElementById("cd-hours").textContent = pad(Math.floor(d%86400000/3600000));
  document.getElementById("cd-mins").textContent  = pad(Math.floor(d%3600000/60000));
  document.getElementById("cd-secs").textContent  = pad(Math.floor(d%60000/1000));
}
updateCd(); setInterval(updateCd, 1000);

/* ======= SCHEDULE ACCORDION ======= */
function toggleDay(header) {
  const day = header.parentElement;
  day.classList.toggle("open");
}

/* ======= DRAW TABS ======= */
function switchTab(btn, draw) {
  document.querySelectorAll(".draw-tab").forEach(t => t.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("draw-men").style.display   = draw === "men"   ? "grid" : "none";
  document.getElementById("draw-women").style.display = draw === "women" ? "grid" : "none";
}

/* ======= LANGUAGE SYSTEM ======= */
let currentLang = "en";

function setLang(lang) {
  currentLang = lang;
  document.documentElement.lang = lang;
  document.getElementById("btn-en").classList.toggle("active", lang === "en");
  document.getElementById("btn-es").classList.toggle("active", lang === "es");

  document.querySelectorAll("[data-en]").forEach(el => {
    const val = el.getAttribute("data-" + lang);
    if (val === null) return;
    // If the value contains HTML tags, use innerHTML; else textContent
    if (val.indexOf("<") !== -1) {
      el.innerHTML = val;
    } else {
      el.textContent = val;
    }
  });
  if (window.MSO_setNewsLang) window.MSO_setNewsLang(lang);
}

/* ======= SCROLL REVEAL ======= */
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity="1"; e.target.style.transform="translateY(0)"; }
  });
}, { threshold: 0.08 });
document.querySelectorAll(".section, #info-band, .ticket-card, .stat-card, .schedule-day, .news-card, .partner-logo, .gallery-item, .venue-info, .social-links").forEach(el => {
  el.style.opacity = "0";
  el.style.transform = "translateY(24px)";
  el.style.transition = "opacity .55s ease, transform .55s ease";
  observer.observe(el);
});

/* ======= HAMBURGER TOGGLE ======= */
const hamburger = document.getElementById("hamburger");
const mobileNav  = document.getElementById("mobile-nav");
if (hamburger && mobileNav) {
  hamburger.addEventListener("click", () => mobileNav.classList.toggle("open"));
}

/* ======= BRACKET TAB SCROLLING ======= */
(function() {
  const bracket = document.getElementById("bracket");
  const tabs    = document.querySelectorAll(".bracket-tab");
  if (!bracket || !tabs.length) return;
  let suppressScrollSync = 0;

  // Click handler: smooth-scroll the bracket so the target round is visible at the left.
  // Uses getBoundingClientRect (relative measurement) because .bracket has no positioning
  // context, so round.offsetLeft is computed against a different ancestor and gives wrong values.
  tabs.forEach(tab => {
    tab.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = tab.getAttribute("data-target");
      const round    = document.getElementById(targetId);
      if (!round) return;
      suppressScrollSync = Date.now() + 1000;
      tabs.forEach(t => t.classList.remove("active"));
      tab.classList.add("active");
      // Relative offset of the round within the scroll container
      const bracketRect = bracket.getBoundingClientRect();
      const roundRect   = round.getBoundingClientRect();
      const relativeLeft = bracket.scrollLeft + (roundRect.left - bracketRect.left);
      const targetLeft = Math.max(0, relativeLeft - 4);
      bracket.scrollTo({ left: targetLeft, behavior: "smooth" });
    });
  });

  // Highlight the currently most-visible round as the user scrolls manually
  let scrollTimer;
  bracket.addEventListener("scroll", () => {
    if (Date.now() < suppressScrollSync) return;
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const rounds = bracket.querySelectorAll(".bracket-round");
      const bracketRect = bracket.getBoundingClientRect();
      const targetScroll = bracket.scrollLeft + bracket.clientWidth * 0.25; // 25% from left
      let closest = rounds[0];
      let closestDist = Infinity;
      rounds.forEach(r => {
        const relLeft = bracket.scrollLeft + (r.getBoundingClientRect().left - bracketRect.left);
        const dist = Math.abs(relLeft - targetScroll);
        if (dist < closestDist) { closestDist = dist; closest = r; }
      });
      tabs.forEach(t => t.classList.toggle("active", t.getAttribute("data-target") === closest.id));
    }, 80);
  }, { passive: true });
})();
</script>
<script src="/draw-hydrate.js" defer></script>
<script src="/news-hydrate.js" defer></script>
<script src="/replays-hydrate.js" defer></script>
<script src="/gallery-hydrate.js" defer></script>
</body>
</html>
