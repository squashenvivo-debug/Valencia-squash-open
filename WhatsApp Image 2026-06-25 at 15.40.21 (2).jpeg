<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Madrid Squash Open 2026 | PSA 15K Challenger</title>
  <meta name="description" content="PSA 15K Challenger – Madrid Squash Open 2026. Club de Squash Tres Cantos, 23-27 Junio / June 2026."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Barlow+Condensed:wght@400;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.5.0/css/flag-icons.min.css"/>
  <link rel="stylesheet" href="/news-styles.css"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"/>
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"/>
  <link rel="icon" href="/favicon.ico" sizes="any"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
  <link rel="manifest" href="/site.webmanifest"/>
  <meta name="theme-color" content="#001b2d"/>
  <link rel="stylesheet" href="/replays-styles.css"/>
  <link rel="stylesheet" href="/gallery-styles.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy:     #001b2d;
      --navy2:    #002d4c;
      --navy3:    #003c66;
      --navy4:    #004d82;
      --accent:   #00a8e8;
      --gold:     #f0c330;
      --gold2:    #c9a227;
      --white:    #ffffff;
      --text:     #d8e8f4;
      --muted:    #7ba0bb;
      --red:      #c8102e;
      --nav-h:    72px;
      --ease:     cubic-bezier(.22,.68,0,1.2);
    }
    html { scroll-behavior: smooth; }
    body { background: var(--navy); color: var(--text); font-family: "Barlow", sans-serif; font-weight: 400; line-height: 1.6; overflow-x: hidden; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .section { padding: 96px 0; }
    .label {
      display: inline-block; font-family: "Barlow Condensed", sans-serif; font-weight: 700;
      font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
    }
    h2.section-title {
      font-family: "Bebas Neue", sans-serif; font-size: clamp(2.6rem, 6vw, 4.2rem);
      line-height: 1; color: var(--white); margin-bottom: 20px;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 10px; padding: 14px 32px;
      font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1rem;
      letter-spacing: .1em; text-transform: uppercase; border-radius: 3px;
      transition: transform .2s var(--ease), box-shadow .2s, background .2s;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn-accent { background: var(--accent); color: var(--navy); box-shadow: 0 4px 24px rgba(0,168,232,.3); }
    .btn-accent:hover { background: #1bb5f5; box-shadow: 0 8px 32px rgba(0,168,232,.5); }
    .btn-outline { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,.3); }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
    .btn-gold { background: var(--gold); color: var(--navy); box-shadow: 0 4px 24px rgba(240,195,48,.25); }
    .btn-gold:hover { background: #f5d060; }

    /* ======= LANG TOGGLE ======= */
    #lang-toggle {
      position: fixed; top: 16px; right: 80px; z-index: 1100;
      display: flex; gap: 4px; align-items: center;
      background: rgba(0,27,45,.8); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.1); border-radius: 20px;
      padding: 4px 6px;
    }
    .lang-btn {
      font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .78rem;
      letter-spacing: .1em; text-transform: uppercase; padding: 5px 10px;
      border-radius: 14px; color: var(--muted); transition: background .2s, color .2s;
      display: flex; align-items: center; gap: 5px;
    }
    .lang-btn.active { background: var(--navy3); color: var(--white); }
    .lang-flag { font-size: .9rem; }

    /* ======= NAVBAR ======= */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h); display: flex; align-items: center;
      transition: background .3s, backdrop-filter .3s, box-shadow .3s;
    }
    #navbar.scrolled {
      background: rgba(0,27,45,.95); backdrop-filter: blur(16px);
      box-shadow: 0 1px 0 rgba(255,255,255,.06);
    }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; }
    .nav-logo { display: flex; align-items: center; gap: 10px; }
    .nav-logo img { height: 44px; width: auto; }
    .nav-links { display: flex; align-items: center; gap: 2px; }
    .nav-links a {
      font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .82rem;
      letter-spacing: .1em; text-transform: uppercase; color: var(--muted);
      padding: 8px 11px; border-radius: 3px; transition: color .2s, background .2s;
    }
    .nav-links a:hover { color: var(--white); background: rgba(255,255,255,.06); }
    .nav-cta { margin-left: 12px; }
    #menu-toggle { display: none; flex-direction: column; gap: 5px; padding: 8px; }
    #menu-toggle span { display: block; width: 24px; height: 2px; background: var(--text); border-radius: 2px; }

    /* ======= HERO ======= */
    #hero {
      position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 60% 80% at 100% 50%, rgba(0,77,130,.45) 0%, transparent 65%),
        radial-gradient(ellipse 50% 60% at 0% 100%, rgba(0,20,40,.9) 0%, transparent 60%),
        linear-gradient(160deg, #000e1a 0%, #001525 60%, #001830 100%);
    }
    .hero-bg::after {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,168,232,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,168,232,.035) 1px, transparent 1px);
      background-size: 55px 55px;
      mask-image: radial-gradient(ellipse 90% 90% at 85% 40%, black 0%, transparent 70%);
    }
    .hero-poster {
      position: absolute; right: 0; top: 0; height: 100%; width: 42%;
      z-index: 1; overflow: hidden;
    }
    .hero-poster img {
      height: 100%; width: 100%; object-fit: cover; object-position: center top;
      opacity: .35; mask-image: linear-gradient(to right, transparent 0%, black 30%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%);
    }
    .hero-content {
      position: relative; z-index: 2; padding-top: var(--nav-h);
    }
    .hero-eyebrow { display: flex; align-items: center; gap: 14px; margin-bottom: 28px; animation: fadeUp .8s .1s both; }
    .psa-badge {
      background: var(--gold); color: var(--navy); font-family: "Barlow Condensed", sans-serif;
      font-weight: 800; font-size: .7rem; letter-spacing: .16em; padding: 5px 10px; border-radius: 2px;
    }
    .event-cat { color: var(--muted); font-size: .8rem; font-family: "Barlow Condensed", sans-serif; letter-spacing: .14em; text-transform: uppercase; }
    h1.hero-title {
      font-family: "Bebas Neue", sans-serif; font-size: clamp(3.5rem, 10vw, 8.5rem);
      line-height: .95; color: var(--white); margin-bottom: 24px;
      animation: fadeUp .8s .2s both;
    }
    h1.hero-title em { color: var(--accent); font-style: normal; }
    .hero-meta {
      display: flex; align-items: center; gap: 28px; margin-bottom: 40px;
      flex-wrap: wrap; animation: fadeUp .8s .3s both;
    }
    .hero-meta-item { display: flex; flex-direction: column; gap: 2px; }
    .meta-label { font-size: .68rem; font-family: "Barlow Condensed", sans-serif; letter-spacing: .15em; text-transform: uppercase; color: var(--muted); }
    .meta-value { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1rem; color: var(--white); }
    .hero-meta-sep { width: 1px; height: 32px; background: rgba(255,255,255,.12); }
    .hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; animation: fadeUp .8s .4s both; }

    /* countdown */
    #countdown {
      display: flex; animation: fadeUp .8s .6s both;
      margin-top: 80px; justify-content: center;
    }
    .cd-item { text-align: center; padding: 14px 26px; border: 1px solid rgba(255,255,255,.1); background: rgba(0,27,45,.6); backdrop-filter: blur(8px); }
    .cd-item + .cd-item { border-left: none; }
    .cd-num { display: block; font-family: "Bebas Neue", sans-serif; font-size: 2.4rem; color: var(--gold); line-height: 1; }
    .cd-label { display: block; font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-top: 4px; }
    .scroll-hint { position: absolute; bottom: 32px; right: 40px; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 6px; color: var(--muted); font-size: .65rem; letter-spacing: .14em; text-transform: uppercase; font-family: "Barlow Condensed", sans-serif; animation: fadeIn 1s 1s both; }
    .scroll-hint::after { content: ""; display: block; width: 1px; height: 40px; background: linear-gradient(var(--muted), transparent); animation: scrollPulse 1.8s infinite; }

    /* ======= INFO BAND ======= */
    #info-band { background: var(--accent); padding: 0; overflow: hidden; }
    .info-band-inner { display: flex; align-items: stretch; }
    .info-band-item { flex: 1; padding: 26px 28px; display: flex; align-items: center; gap: 14px; border-right: 1px solid rgba(0,27,45,.15); }
    .info-band-item:last-child { border-right: none; }
    .info-band-icon { width: 38px; height: 38px; background: rgba(0,27,45,.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .info-band-icon svg { width: 18px; height: 18px; fill: var(--navy); }
    .info-band-label { font-size: .65rem; font-family: "Barlow Condensed", sans-serif; letter-spacing: .14em; text-transform: uppercase; color: rgba(0,27,45,.7); display: block; }
    .info-band-value { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1rem; color: var(--navy); }

    /* ======= ABOUT ======= */
    #about { background: var(--navy2); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
    .about-text p { color: var(--muted); margin-bottom: 16px; font-size: 1.02rem; line-height: 1.78; }
    .about-text p strong { color: var(--text); font-weight: 600; }
    .about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 36px; }
    .stat-card { background: var(--navy3); padding: 22px; }
    .stat-num { font-family: "Bebas Neue", sans-serif; font-size: 2.8rem; color: var(--accent); line-height: 1; }
    .stat-desc { font-size: .75rem; font-family: "Barlow Condensed", sans-serif; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-top: 4px; }
    .about-visual { position: relative; }
    .about-img-wrap { position: relative; overflow: hidden; border-radius: 3px; }
    .about-img-wrap img { width: 100%; height: auto; display: block; }
    .about-accent-bar { position: absolute; top: 24px; left: -10px; width: 4px; height: 80px; background: var(--accent); border-radius: 2px; }
    .about-psa-badge { position: absolute; bottom: 20px; right: -10px; background: var(--gold); color: var(--navy); padding: 12px 16px; font-family: "Bebas Neue", sans-serif; font-size: 1rem; line-height: 1.2; text-align: center; }

    /* ======= SCHEDULE ======= */
    #schedule { background: var(--navy); }
    .schedule-days { display: flex; flex-direction: column; gap: 2px; margin-top: 8px; }
    .schedule-day {
      background: var(--navy2); border-left: 3px solid var(--navy3);
      transition: border-color .2s;
    }
    .schedule-day:hover { border-color: var(--accent); }
    .schedule-day-header {
      padding: 18px 24px; display: flex; align-items: center; gap: 20px;
      cursor: pointer; user-select: none;
    }
    .schedule-day-date {
      font-family: "Bebas Neue", sans-serif; font-size: 1.6rem; color: var(--accent);
      min-width: 44px; text-align: center; line-height: 1;
    }
    .schedule-day-info { flex: 1; }
    .schedule-day-name {
      font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1.05rem;
      color: var(--white); text-transform: uppercase; letter-spacing: .06em;
    }
    .schedule-day-round { font-size: .82rem; color: var(--muted); }
    .schedule-day-arrow { color: var(--muted); font-size: 1.1rem; transition: transform .3s; }
    .schedule-day.open .schedule-day-arrow { transform: rotate(180deg); }
    .schedule-day-body { display: none; padding: 0 24px 20px; }
    .schedule-day.open .schedule-day-body { display: block; }
    .schedule-row { display: flex; align-items: flex-start; gap: 20px; padding: 10px 0; border-top: 1px solid rgba(255,255,255,.05); }
    .schedule-time { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .95rem; color: var(--gold); min-width: 80px; flex-shrink: 0; }
    .schedule-desc { font-size: .9rem; color: var(--muted); line-height: 1.5; }
    .schedule-desc strong { color: var(--text); }
    .schedule-special { background: rgba(0,168,232,.08); padding: 10px 14px; border-radius: 2px; margin-top: 4px; display: flex; align-items: center; gap: 10px; }
    .schedule-special-icon { font-size: 1.1rem; }

    /* ======= TICKETS ======= */
    #tickets { background: var(--navy2); position: relative; overflow: hidden; }
    #tickets::before { content: ""; position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; background: radial-gradient(circle, rgba(0,168,232,.08), transparent 60%); pointer-events: none; }
    .tickets-header { text-align: center; max-width: 600px; margin: 0 auto 52px; }
    .tickets-header p { color: var(--muted); font-size: 1.02rem; }
    .ticket-tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; max-width: 900px; margin: 0 auto 48px; }
    .ticket-card { background: var(--navy3); padding: 34px 26px; position: relative; transition: transform .3s var(--ease); }
    .ticket-card:hover { transform: translateY(-6px); }
    .ticket-card.featured { background: linear-gradient(135deg, var(--navy4), var(--navy3)); border: 1px solid rgba(0,168,232,.3); }
    .ticket-featured-label { position: absolute; top: -1px; left: 50%; transform: translateX(-50%); background: var(--gold); color: var(--navy); font-family: "Barlow Condensed", sans-serif; font-weight: 800; font-size: .62rem; letter-spacing: .15em; text-transform: uppercase; padding: 4px 14px; }
    .ticket-name { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .95rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
    .ticket-price { font-family: "Bebas Neue", sans-serif; font-size: 3rem; color: var(--white); line-height: 1; margin-bottom: 4px; }
    .ticket-price sup { font-size: 1.3rem; vertical-align: super; }
    .ticket-desc { color: var(--muted); font-size: .82rem; margin-bottom: 22px; }
    .ticket-features { display: flex; flex-direction: column; gap: 9px; margin-bottom: 26px; }
    .ticket-feature { display: flex; align-items: flex-start; gap: 9px; font-size: .85rem; color: var(--muted); }
    .ticket-feature::before { content: "✓"; color: var(--gold); font-weight: 700; flex-shrink: 0; }
    #future-ticketing-widget { max-width: 900px; margin: 0 auto; padding: 32px; background: var(--navy); border: 1px solid rgba(255,255,255,.06); }
    .tickets-concluded { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }

    /* ======= DRAW ======= */
    #draw { background: var(--navy); }
    .draw-tabs { display: flex; gap: 4px; margin-bottom: 36px; }
    .draw-tab { padding: 10px 24px; font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .9rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); background: var(--navy2); border-radius: 3px; transition: color .2s, background .2s; }
    .draw-tab.active { background: var(--accent); color: var(--navy); }
    .draw-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
    .player-card { background: var(--navy2); padding: 18px; border-radius: 2px; display: flex; align-items: center; gap: 12px; transition: transform .25s var(--ease); }
    .player-card:hover { transform: translateY(-3px); }
    .player-seed { font-family: "Bebas Neue", sans-serif; font-size: 1.5rem; color: var(--accent); width: 26px; text-align: center; flex-shrink: 0; }
    .player-info { min-width: 0; }
    .player-name { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1rem; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .player-country { font-size: .75rem; color: var(--muted); font-family: "Barlow Condensed", sans-serif; }
    .player-rank { margin-left: auto; font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .75rem; color: var(--gold); background: rgba(240,195,48,.1); padding: 4px 8px; border-radius: 2px; flex-shrink: 0; font-variant-numeric: tabular-nums; }
    /* tighter name layout to fit 24 cards in the grid cleanly */
    .player-name { font-size: .95rem; white-space: normal; line-height: 1.2; }
    .player-card { min-height: 66px; align-items: center; }
    /* seed badge variants */
    .player-seed.seed-group { font-size: .95rem; letter-spacing: -.02em; }       /* "9/16" */
    .player-seed.seed-none  { color: var(--muted); font-size: 1.6rem; line-height: 1; } /* "—" */
    .player-seed.seed-wc    { color: var(--gold); font-size: 1.4rem; }            /* confirmed WC */
    .player-seed.seed-wc-tbd{ color: var(--muted); font-size: 1.4rem; }           /* qualifier WC */
    .player-card.wildcard-confirmed { border-left: 3px solid var(--gold); padding-left: 15px; background: linear-gradient(90deg, rgba(240,195,48,.08), var(--navy2) 60%); }
    .player-card.wildcard-tbd { border: 1px dashed rgba(123,160,187,.28); background: rgba(0,27,45,.5); padding: 17px; }
    .player-card.wildcard-tbd .player-name { color: var(--muted); font-style: italic; }
    .player-card.wildcard-tbd .player-rank { color: var(--muted); background: rgba(123,160,187,.08); }
    .player-flag {
      width: 28px; height: 21px; flex-shrink: 0;
      border-radius: 2px;
      box-shadow: 0 0 0 1px rgba(255,255,255,.1), 0 1px 4px rgba(0,0,0,.25);
      background-size: cover; background-position: center;
    }
    .player-card.wildcard-tbd .player-flag { visibility: hidden; }
    .draw-note { margin-top: 22px; text-align: center; color: var(--muted); font-size: .85rem; }
    .draw-legend { display: flex; flex-wrap: wrap; gap: 18px 28px; justify-content: center; margin-top: 18px; font-family: "Barlow Condensed", sans-serif; font-size: .78rem; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); }
    .draw-legend span strong { color: var(--white); font-weight: 700; margin-right: 6px; }

    /* ======= BRACKET ======= */
    .bracket-wrap { margin-top: 56px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.06); }
    .bracket-header { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 18px; }
    .bracket-title { font-family: "Barlow Condensed", sans-serif; font-weight: 800; font-size: 1rem; letter-spacing: .18em; text-transform: uppercase; color: var(--white); }
    .bracket-tabs { display: flex; gap: 4px; flex-wrap: wrap; }
    .bracket-tab { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .72rem; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); background: var(--navy2); padding: 6px 12px; border-radius: 3px; border: 1px solid transparent; transition: color .2s, background .2s, border-color .2s; cursor: pointer; }
    .bracket-tab:hover { color: var(--white); border-color: rgba(0,168,232,.3); }
    .bracket-tab.active { background: var(--accent); color: var(--navy); border-color: var(--accent); }
    .bracket-scroll-hint { display: none; text-align: center; color: var(--muted); font-family: "Barlow Condensed", sans-serif; font-size: .78rem; letter-spacing: .1em; text-transform: uppercase; padding: 6px 0 12px; }
    .bracket-scroll-hint::after { content: " →"; color: var(--accent); }
    .bracket { --line: rgba(0,168,232,.3); display: flex; gap: 36px; overflow-x: auto; overflow-y: hidden; padding: 8px 4px 18px; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; }
    .bracket::-webkit-scrollbar { height: 8px; }
    .bracket::-webkit-scrollbar-track { background: rgba(255,255,255,.04); border-radius: 4px; }
    .bracket::-webkit-scrollbar-thumb { background: rgba(0,168,232,.4); border-radius: 4px; }
    .bracket-round { display: flex; flex-direction: column; flex-shrink: 0; width: 320px; }
    /* layout block — kept for selectors below */
    .match-block { flex: 1; }
    .match { width: 100%; background: var(--navy2); border-radius: 3px; border: 1px solid rgba(255,255,255,.05); overflow: hidden; }
    /* Player row: [seed][flag][name flex][total][g1][g2][g3][g4][g5] */
    .match-player {
      display: grid;
      grid-template-columns: 18px 20px 1fr 28px repeat(5, 22px);
      align-items: center; gap: 6px; padding: 8px 10px;
      font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .82rem;
      color: var(--text); border-bottom: 1px solid rgba(255,255,255,.05);
    }
    .match-player:last-child { border-bottom: none; }
    .match-player.bye { color: var(--muted); font-style: italic; background: rgba(0,0,0,.12); }
    .match-player.tbd { color: var(--muted); }
    .match-player.tbd .player-name-mini { font-style: italic; }
    .match-player.winner { color: var(--white); }
    .player-seed-mini { font-size: .65rem; color: var(--accent); font-weight: 800; letter-spacing: .03em; text-align: center; }
    .player-flag-mini { width: 20px; height: 14px; border-radius: 1px; box-shadow: 0 0 0 1px rgba(255,255,255,.08); background-size: cover; background-position: center; }
    .player-flag-mini.empty { visibility: hidden; }
    .player-name-mini { min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2; }

    /* Total games column — bold/prominent; gold when winner */
    .match-score-mini { font-size: 1rem; color: var(--muted); font-variant-numeric: tabular-nums; font-weight: 800; text-align: center; padding: 2px 4px; background: rgba(0,0,0,.25); border-radius: 3px; line-height: 1.2; }
    .match-player.winner .match-score-mini { color: var(--gold); background: rgba(240,195,48,.15); }

    /* Per-game score cells — smaller, muted, tabular */
    .match-game-cell { font-size: .78rem; color: var(--muted); font-variant-numeric: tabular-nums; font-weight: 700; text-align: center; line-height: 1.2; }
    .match-player.winner .match-game-cell { color: var(--text); }
    .match-game-cell.empty { color: rgba(123,160,187,.35); }

    /* In-progress match — pulsing LIVE indicator in the meta strip */
    .match.is-live { box-shadow: 0 0 0 1px rgba(255,80,80,.4), 0 0 12px rgba(255,80,80,.18); }
    .match.is-live .match-meta::before {
      content: "● LIVE · ";
      color: #ff5050;
      font-weight: 800;
      letter-spacing: .04em;
      animation: live-pulse 1.6s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .45; }
    }
    .match.is-live .match-player .match-score-mini { color: var(--white); }
    .bracket-round-header { text-align: center; font-family: "Barlow Condensed", sans-serif; font-weight: 800; font-size: .82rem; letter-spacing: .18em; text-transform: uppercase; color: var(--accent); padding: 10px 0; margin-bottom: 12px; background: rgba(0,168,232,.08); border-radius: 3px; }
    .bracket-round-body { flex: 1; display: flex; flex-direction: column; gap: 6px; }
    .match-slot { flex: 1; display: flex; align-items: center; position: relative; }
    .bracket-round[data-round="l16"] .match-slot { flex: 2; }
    .bracket-round[data-round="qf"] .match-slot { flex: 4; }
    .bracket-round[data-round="sf"] .match-slot { flex: 8; }
    .bracket-round[data-round="f"] .match-slot { flex: 16; }
    /* Right-going connector line: rounds 1-4 */
    .bracket-round:not([data-round="f"]) .match-slot::after { content: ''; position: absolute; top: 50%; left: 100%; width: 18px; height: 2px; background: var(--line); transform: translateY(-1px); pointer-events: none; }
    /* T-shape on left (vertical line + horizontal stub): rounds 2-5 — extended ~3px past 25%/75% to bridge match-slot gap */
    .bracket-round:not([data-round="r1"]) .match-slot::before { content: ''; position: absolute; top: calc(25% - 3px); bottom: calc(25% - 3px); right: 100%; width: 18px; background: linear-gradient(to right, var(--line) 2px, transparent 2px) 0 0 / 100% 100% no-repeat, linear-gradient(var(--line), var(--line)) 0 50% / 100% 2px no-repeat; pointer-events: none; }
    /* Match meta header (date · time · court) */
    .match-meta { display: block; font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); padding: 4px 10px 3px; background: rgba(0,168,232,.06); border-bottom: 1px solid rgba(255,255,255,.06); text-align: center; line-height: 1.2; }
    .match-meta.scheduled { color: var(--accent); }

    /* ======= NEWS ======= */
    #news { background: var(--navy2); }
    .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
    .news-card { background: var(--navy3); overflow: hidden; transition: transform .3s var(--ease); cursor: pointer; }
    .news-card:hover { transform: translateY(-4px); }
    .news-card:hover .news-img-inner { transform: scale(1.05); }
    .news-img { aspect-ratio: 16/9; overflow: hidden; position: relative; }
    .news-img-inner { width: 100%; height: 100%; transition: transform .5s var(--ease); }
    .news-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--navy) 0%, var(--navy4) 100%); display: flex; align-items: center; justify-content: center; }
    .news-placeholder svg { width: 36px; height: 36px; opacity: .15; fill: var(--text); }
    .news-category { position: absolute; top: 12px; left: 12px; background: var(--accent); color: var(--navy); font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .62rem; letter-spacing: .14em; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; }
    .news-body { padding: 22px; }
    .news-date { font-size: .7rem; font-family: "Barlow Condensed", sans-serif; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); margin-bottom: 9px; }
    .news-headline { font-family: "Barlow", sans-serif; font-weight: 700; font-size: .98rem; line-height: 1.4; color: var(--white); margin-bottom: 9px; }
    .news-excerpt { font-size: .85rem; color: var(--muted); line-height: 1.6; }

    /* ======= GALLERY ======= */
    #gallery { background: var(--navy); }
    .gallery-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .gallery-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; }
    .gallery-item { overflow: hidden; cursor: pointer; position: relative; background: var(--navy2); }
    .gallery-item::after { content: ""; position: absolute; inset: 0; background: rgba(0,168,232,0); transition: background .3s; }
    .gallery-item:hover::after { background: rgba(0,168,232,.25); }
    .gallery-item .g-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
    .gallery-item:hover .g-img { transform: scale(1.07); }
    .g-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; min-height: 140px; }
    .g-placeholder svg { width: 24px; height: 24px; opacity: .12; fill: var(--text); }
    .gallery-item:nth-child(1) { grid-column: span 3; aspect-ratio: 16/9; }
    .gallery-item:nth-child(2) { grid-column: span 2; aspect-ratio: 4/3; }
    .gallery-item:nth-child(3) { grid-column: span 1; aspect-ratio: 3/4; }
    .gallery-item:nth-child(4) { grid-column: span 1; aspect-ratio: 1; }
    .gallery-item:nth-child(5) { grid-column: span 2; aspect-ratio: 4/3; }
    .gallery-item:nth-child(6) { grid-column: span 3; aspect-ratio: 21/9; }
    .instagram-strip { background: var(--navy2); padding: 36px 0; text-align: center; margin-top: 4px; }
    .instagram-strip p { color: var(--muted); margin-bottom: 18px; font-size: 1rem; }

    /* ======= VENUE ======= */
    #venue { background: var(--navy2); }
    .venue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
    .venue-map { background: var(--navy3); border-radius: 4px; overflow: hidden; aspect-ratio: 4/3; position: relative; }
    .venue-map iframe { width: 100%; height: 100%; border: 0; }
    .venue-details { display: flex; flex-direction: column; gap: 22px; }
    .venue-block h3 { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
    .venue-block p { color: var(--text); font-size: .98rem; line-height: 1.65; }
    .venue-block a { color: var(--accent); }
    .venue-block a:hover { text-decoration: underline; }
    .schedule-table { width: 100%; border-collapse: collapse; margin-top: 6px; }
    .schedule-table tr + tr td { border-top: 1px solid rgba(255,255,255,.06); }
    .schedule-table td { padding: 9px 0; font-size: .88rem; color: var(--muted); }
    .schedule-table td:first-child { font-family: "Barlow Condensed", sans-serif; font-weight: 700; color: var(--white); width: 110px; }

    /* ======= PARTNERS ======= */
    #partners { background: var(--navy); }
    .partners-header { text-align: center; margin-bottom: 48px; }
    .partner-tiers { display: flex; flex-direction: column; gap: 36px; }
    .partner-tier-label { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; text-align: center; }
    .partner-row { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; }
    .partner-logo { background: var(--navy2); padding: 18px 28px; border-radius: 3px; display: flex; align-items: center; justify-content: center; min-width: 140px; transition: transform .2s var(--ease), background .2s; cursor: pointer; border: 1px solid rgba(255,255,255,.05); }
    .partner-logo:hover { transform: translateY(-3px); background: var(--navy3); }
    .partner-logo span { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: 1rem; letter-spacing: .06em; text-transform: uppercase; color: var(--muted); text-align: center; }
    .partner-logo.main span { font-size: 1.3rem; color: var(--text); }
    .partner-logo img { max-height: 70px; width: auto; object-fit: contain; }
    .partner-logo.main img { max-height: 90px; }
    .partner-cta { text-align: center; margin-top: 48px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.06); }
    .partner-cta p { color: var(--muted); margin-bottom: 18px; }

    /* ======= WATCH ======= */
    #watch { background: var(--navy2); }
    .watch-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
    .watch-card { background: var(--navy3); padding: 36px; display: flex; flex-direction: column; gap: 14px; }
    .watch-card h3 { font-family: "Bebas Neue", sans-serif; font-size: 1.9rem; color: var(--white); }
    .watch-card p { color: var(--muted); line-height: 1.72; }
    .watch-icon { width: 48px; height: 48px; background: rgba(0,168,232,.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .watch-icon svg { width: 22px; height: 22px; fill: var(--accent); }

    /* ======= FOOTER ======= */
    footer { background: #00101d; padding: 56px 0 28px; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 44px; padding-bottom: 44px; border-bottom: 1px solid rgba(255,255,255,.06); }
    .footer-logo img { height: 52px; width: auto; margin-bottom: 14px; }
    .footer-brand p { color: var(--muted); font-size: .86rem; line-height: 1.7; max-width: 270px; }
    .footer-social { display: flex; gap: 10px; margin-top: 18px; }
    .social-btn { width: 34px; height: 34px; background: rgba(255,255,255,.06); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background .2s, transform .2s; }
    .social-btn:hover { background: var(--accent); transform: translateY(-2px); }
    .social-btn svg { width: 15px; height: 15px; fill: var(--text); }
    .footer-col h4 { font-family: "Barlow Condensed", sans-serif; font-weight: 700; font-size: .72rem; letter-spacing: .15em; text-transform: uppercase; color: var(--white); margin-bottom: 14px; }
    .footer-col ul { display: flex; flex-direction: column; gap: 9px; }
    .footer-col ul li a { color: var(--muted); font-size: .86rem; transition: color .2s; }
    .footer-col ul li a:hover { color: var(--text); }
    .footer-bottom { padding-top: 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-bottom p { color: var(--muted); font-size: .78rem; }
    .footer-psa { display: flex; align-items: center; gap: 8px; font-size: .78rem; color: var(--muted); font-family: "Barlow Condensed", sans-serif; }
    .footer-psa strong { color: var(--gold); }

    /* ======= MOBILE NAV ======= */
    #mobile-nav { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(0,15,25,.97); backdrop-filter: blur(20px); flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
    #mobile-nav.open { display: flex; }
    #mobile-nav a { font-family: "Bebas Neue", sans-serif; font-size: 2.1rem; color: var(--text); letter-spacing: .06em; padding: 7px 0; transition: color .2s; }
    #mobile-nav a:hover { color: var(--gold); }
    #mobile-nav .close-nav { position: absolute; top: 24px; right: 24px; color: var(--muted); font-size: 1.5rem; cursor: pointer; }

    /* ======= KEYFRAMES ======= */
    @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
    @keyframes scrollPulse { 0%,100% { opacity:.3; transform:scaleY(1); } 50% { opacity:1; transform:scaleY(1.4); } }

    /* ======= RESPONSIVE ======= */
    @media (max-width:1024px) {
      .about-grid, .venue-grid { grid-template-columns: 1fr; gap: 36px; }
      .draw-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width:768px) {
      .section { padding: 60px 0; }
      .nav-links, .nav-cta { display: none; }
      #menu-toggle { display: flex; }
      .nav-logo img { height: 30px; }
      #menu-toggle { padding: 8px 4px; }
      #lang-toggle { position: fixed; top: 22px; right: 52px; padding: 2px 4px; }
      .lang-btn { font-size: .62rem; padding: 3px 5px; gap: 2px; }
      .lang-flag { font-size: .68rem; }
      .info-band-inner { flex-direction: column; }
      .info-band-item { border-right: none; border-bottom: 1px solid rgba(0,27,45,.15); }
      .ticket-tiers { grid-template-columns: 1fr; max-width: 360px; margin-left: auto; margin-right: auto; }
      .news-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-item { grid-column: span 1 !important; aspect-ratio: 4/3 !important; }
      .watch-grid { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr; gap: 28px; }
      #countdown { margin-top: 32px; width: 100%; }
      .cd-item { flex: 1; padding: 12px 8px; }
      .scroll-hint { display: none; }
      .hero-content { padding-bottom: 24px; }
      .bracket-scroll-hint { display: block; }
      .bracket-round { width: 270px; }
      .bracket .match-player { grid-template-columns: 16px 18px 1fr 26px repeat(5, 19px); font-size: .78rem; padding: 7px 8px; gap: 5px; }
      .bracket .match-game-cell { font-size: .72rem; }
    }
    @media (max-width:480px) {
      h1.hero-title { font-size: 3.3rem; }
      .hero-meta { gap: 14px; }
      .hero-meta-sep { display: none; }
      .draw-grid { grid-template-columns: 1fr; }
      .nav-logo img { height: 28px; }
      .bracket-round { width: 232px; }
      .bracket .player-flag-mini { width: 16px; height: 11px; }
      .bracket .match-player { grid-template-columns: 14px 16px 1fr 22px repeat(5, 16px); font-size: .72rem; padding: 6px 6px; gap: 4px; }
      .bracket .match-game-cell { font-size: .68rem; }
      .bracket .match-score-mini { font-size: .88rem; padding: 1px 2px; }
      .bracket .player-seed-mini { font-size: .6rem; min-width: 12px; }
    }
  </style>
</head>
<body>

<!-- LANG TOGGLE -->
<div id="lang-toggle">
  <button class="lang-btn active" onclick="setLang('en')" id="btn-en"><span class="lang-flag">🇬🇧</span> EN</button>
  <button class="lang-btn" onclick="setLang('es')" id="btn-es"><span class="lang-flag">🇪🇸</span> ES</button>
</div>

<!-- NAVBAR -->
<nav id="navbar">
  <div class="container">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo" aria-label="Madrid Squash Open">
        <img src="images/partners/Madrid-Squash-Open-blanco.png" alt="Madrid Squash Open logo" height="44">
      </a>
      <ul class="nav-links">
        <li><a href="#about" data-en="Info" data-es="Info">Info</a></li>
        <li><a href="#schedule" data-en="Schedule" data-es="Horario">Schedule</a></li>
        <li><a href="#tickets" data-en="Tickets" data-es="Entradas">Tickets</a></li>
        <li><a href="#draw" data-en="Draw" data-es="Cuadro">Draw</a></li>
        <li><a href="#news" data-en="News" data-es="Noticias">News</a></li>
        <li><a href="#gallery" data-en="Gallery" data-es="Galería">Gallery</a></li>
        <li><a href="#venue" data-en="Venue" data-es="Sede">Venue</a></li>
        <li><a href="#partners" data-en="Partners" data-es="Patrocinadores">Partners</a></li>
        <li><a href="#watch" data-en="Watch" data-es="Ver">Watch</a></li>
      </ul>
      <a href="#draw" class="btn btn-accent nav-cta" data-en="View Results" data-es="Ver Resultados">View Results</a>
      <button id="menu-toggle" onclick="document.getElementById('mobile-nav').classList.add('open')" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- MOBILE NAV -->
<div id="mobile-nav">
  <button class="close-nav" onclick="document.getElementById('mobile-nav').classList.remove('open')">✕</button>
  <a href="#about"    onclick="closeMobile()" data-en="Info"       data-es="Info">Info</a>
  <a href="#schedule" onclick="closeMobile()" data-en="Schedule"   data-es="Horario">Schedule</a>
  <a href="#tickets"  onclick="closeMobile()" data-en="Tickets"    data-es="Entradas">Tickets</a>
  <a href="#draw"     onclick="closeMobile()" data-en="Draw"       data-es="Cuadro">Draw</a>
  <a href="#news"     onclick="closeMobile()" data-en="News"       data-es="Noticias">News</a>
  <a href="#gallery"  onclick="closeMobile()" data-en="Gallery"    data-es="Galería">Gallery</a>
  <a href="#venue"    onclick="closeMobile()" data-en="Venue"      data-es="Sede">Venue</a>
  <a href="#partners" onclick="closeMobile()" data-en="Partners"   data-es="Patrocinadores">Partners</a>
  <a href="#watch"    onclick="closeMobile()" data-en="Watch"      data-es="Ver">Watch</a>
  <a href="#draw"  class="btn btn-accent" style="margin-top:14px" onclick="closeMobile()" data-en="View Results" data-es="Ver Resultados">View Results</a>
</div>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-poster">
    <img src="images/hero-action.jpg" alt="Professional squash player in action at the Madrid Squash Open" loading="eager"/>
  </div>
  <div class="container hero-content">
    <div class="hero-eyebrow">
      <span class="psa-badge">PSA World Tour</span>
      <span class="event-cat" data-en="15K Challenger · Tres Cantos, Madrid · June 2026" data-es="15K Challenger · Tres Cantos, Madrid · Junio 2026">15K Challenger · Tres Cantos, Madrid · June 2026</span>
    </div>
    <h1 class="hero-title">Madrid<br><em>Squash</em><br>Open</h1>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="meta-label" data-en="Dates" data-es="Fechas">Dates</span>
        <span class="meta-value">23–27 <span data-en="June" data-es="Junio">June</span> 2026</span>
      </div>
      <div class="hero-meta-sep"></div>
      <div class="hero-meta-item">
        <span class="meta-label" data-en="Prize Money" data-es="Premio">Prize Money</span>
        <span class="meta-value">$15,000</span>
      </div>
      <div class="hero-meta-sep"></div>
      <div class="hero-meta-item">
        <span class="meta-label" data-en="Category" data-es="Categoría">Category</span>
        <span class="meta-value">PSA Challenger</span>
      </div>
      <div class="hero-meta-sep"></div>
      <div class="hero-meta-item">
        <span class="meta-label" data-en="Venue" data-es="Sede">Venue</span>
        <span class="meta-value">Club de Squash Tres Cantos</span>
      </div>
    </div>
    <div class="hero-actions">
      <a href="#draw" class="btn btn-accent" data-en="🏆 View Results" data-es="🏆 Ver Resultados">🏆 View Results</a>
      <a href="#about" class="btn btn-outline" data-en="Tournament Info" data-es="Info del Torneo">Tournament Info</a>
    </div>
    <div id="countdown" style="display:none;">
      <div class="cd-item"><span class="cd-num" id="cd-days">--</span><span class="cd-label" data-en="Days" data-es="Días">Days</span></div>
      <div class="cd-item"><span class="cd-num" id="cd-hours">--</span><span class="cd-label" data-en="Hours" data-es="Horas">Hours</span></div>
      <div class="cd-item"><span class="cd-num" id="cd-mins">--</span><span class="cd-label" data-en="Mins" data-es="Mins">Mins</span></div>
      <div class="cd-item"><span class="cd-num" id="cd-secs">--</span><span class="cd-label" data-en="Secs" data-es="Segs">Secs</span></div>
    </div>
  </div>
  <div class="scroll-hint">Scroll</div>
</section>

<!-- INFO BAND -->
<div id="info-band">
  <div class="info-band-inner">
    <div class="info-band-item">
      <div class="info-band-icon"><svg viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg></div>
      <div><span class="info-band-label" data-en="Dates" data-es="Fechas">Dates</span><span class="info-band-value" data-en="23–27 June 2026" data-es="23–27 Junio 2026">23–27 June 2026</span></div>
    </div>
    <div class="info-band-item">
      <div class="info-band-icon"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
      <div><span class="info-band-label" data-en="Venue" data-es="Sede">Venue</span><span class="info-band-value">Club Squash Tres Cantos</span></div>
    </div>
    <div class="info-band-item">
