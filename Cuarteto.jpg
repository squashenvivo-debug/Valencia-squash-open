name: Update gallery.json

# Runs whenever you add/remove/rename files in images/gallery/.
# Rebuilds gallery.json and commits it back, so you never edit the JSON by hand.
on:
  push:
    paths:
      - "images/gallery/**"

permissions:
  contents: write   # lets the action commit the regenerated gallery.json

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - name: Rebuild gallery.json
        run: node tools/build-gallery.mjs
      - name: Commit if changed
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add gallery.json
          git diff --staged --quiet || git commit -m "chore: regenerate gallery.json"
          git push
